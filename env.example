# Database (PostgreSQL - e.g. Supabase, Neon, Railway)
DATABASE_URL="postgresql://user:password@host:5432/mooni"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"

# Discord Bot (for auto-joining users to server)
DISCORD_BOT_TOKEN="your-discord-bot-token"
DISCORD_GUILD_ID="1487774939598688267"
DISCORD_ADMIN_ROLE_ID="1487777401927766079"

# Email (Resend - https://resend.com)
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="noreply@mooni.gg"

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
